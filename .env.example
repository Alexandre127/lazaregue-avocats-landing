# Variables d'environnement pour Netlify
# Copiez ce fichier en .env.local pour le développement local

# SendGrid API Key (optionnel - pour envoyer des emails)
# SENDGRID_API_KEY=your_sendgrid_api_key_here

# Email expéditeur (optionnel)
# FROM_EMAIL=noreply@lazaregue-avocats.fr

# Webhook URL (optionnel - pour Zapier, Make, etc.)
# WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/your_webhook_id
